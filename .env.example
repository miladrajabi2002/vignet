# ─── Database (Supabase Postgres + pgvector) ───────────────────────
# Pooled connection (PgBouncer) — used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection — used by Prisma Migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Auth (NextAuth v5) ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# NextAuth v5 also reads AUTH_SECRET; keep them in sync
AUTH_SECRET=""

# ─── SMS / OTP (sms.ir) ────────────────────────────────────────────
SMS_IR_API_KEY=""
SMS_IR_TEMPLATE_ID=""
# Line number for non-OTP notification SMS (sms.ir bulk send). Optional.
SMS_IR_LINE_NUMBER=""

# ─── Encryption (OpenRouter key storage, AES-256-GCM) ──────────────
# 64 hex characters = 32 bytes. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ─── Redis (BullMQ jobs + OTP storage) ─────────────────────────────
REDIS_URL="redis://localhost:6379"
# Set to 1 to process ingestion/embedding inline instead of via the worker
# (handy for dev so you don't need to run `npm run worker`).
DISABLE_QUEUE="0"

# ─── Object Storage (S3-compatible, self-hosted MinIO) ─────────────
# Set up automatically by deploy/setup-server.sh. For an external S3
# provider, point S3_ENDPOINT at it and fill the keys.
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"

# ─── Email (optional — secondary alerts via Resend) ────────────────
RESEND_API_KEY=""
# Verified sender (a domain verified in your Resend account)
RESEND_FROM="Vigent <alerts@vigent.ir>"
# Ops inbox that receives critical platform alerts (e.g. ingestion failures).
# Leave empty to disable email alerts entirely.
ALERT_EMAIL=""

# ─── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WIDGET_URL="http://localhost:3000"
