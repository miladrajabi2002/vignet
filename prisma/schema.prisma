generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// ─── WORKSPACE (TENANT) ───────────────────────────────────────────
model Workspace {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  plan                Plan      @default(TRIAL)
  trialEndsAt         DateTime?
  openrouterKeyEnc    String?
  openrouterKeyHint   String?
  defaultModel        String    @default("deepseek/deepseek-chat")
  defaultEmbedModel   String    @default("text-embedding-3-small")
  defaultTtsVoice     String    @default("alloy")
  language            String    @default("fa")
  onboardingStep      Int       @default(0) // 0-5, tracks activation checklist
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users             User[]
  agents            Agent[]
  contacts          Contact[]
  conversations     Conversation[]
  subscriptions     Subscription[]
  usageLogs         UsageLog[]
  products          Product[]
  productCategories ProductCategory[]
  notifications     Notification[]
  blogPosts         BlogPost[]
  blogCategories    BlogCategory[]
  operatorChannels  OperatorChannel[]
  storeIntegrations StoreIntegration[]
  handoffAlerts     HandoffAlert[]

  @@index([slug])
}

enum Plan {
  TRIAL
  STARTER
  PRO
  BUSINESS
}

// ─── USER (phone-based, no email/password) ────────────────────────
model User {
  id          String   @id @default(cuid())
  workspaceId String
  phone       String   @unique // e.g. +989121234567
  name        String?
  role        UserRole @default(OWNER)
  language    String   @default("fa")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([phone])
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── OTP STORE (audit trail; live OTPs in Redis) ──────────────────
model OTPLog {
  id       String   @id @default(cuid())
  phone    String
  sentAt   DateTime @default(now())
  verified Boolean  @default(false)
  ip       String?

  @@index([phone])
}

// ─── AGENT ────────────────────────────────────────────────────────
model Agent {
  id                      String   @id @default(cuid())
  workspaceId             String
  name                    String
  description             String?
  systemPrompt            String   @db.Text
  model                   String?
  temperature             Float    @default(0.7)
  maxTokens               Int      @default(1000)
  language                String   @default("fa")
  voiceEnabled            Boolean  @default(false)
  ttsVoice                String   @default("alloy")
  avatar                  String?
  welcomeMessage          String?
  fallbackMessage         String?
  handoffEnabled          Boolean  @default(false)
  handoffMessage          String?
  handoffKeywords         String[] @default([])
  active                  Boolean  @default(true)
  flowConfig              Json?
  // ─ 6-LAYER PROMPT ENGINE (F1) ─────────────────────────────────────────
  //   Structured prompt configuration that replaces the single-line systemPrompt
  //   with six composable layers: personality, tone, scope, fallback behavior,
  //   response format, and curated Q&A pairs. When promptConfig is set it takes
  //   precedence over systemPrompt; the legacy field is kept for backward-compat
  //   and as a free-form fallback.
  promptConfig            Json?
  //   Role template key used to seed promptConfig (e.g. 'sales_consult',
  //   'post_sale_support', 'pre_sales', 'follow_up', 'general_support').
  roleTemplate            String?
  // ─ Customer identification (F3): require name + phone at conversation start
  //   before the agent proceeds. Drives the collect-info flow at thread open.
  requireCustomerInfo     Boolean  @default(false)
  customerInfoPrompt      String?  @db.Text
  // ─ A/B experiment (optional): serve a variant system prompt to a % of new
  //   conversations and compare outcomes. Inactive by default.
  experimentActive        Boolean  @default(false)
  experimentVariantPrompt String?  @db.Text
  experimentSplit         Int      @default(50) // % of new conversations served variant B
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  channels        AgentChannel[]
  knowledgeBases  KnowledgeBase[]
  conversations   Conversation[]
  knowledgeChunks KnowledgeChunk[]
  catalogItems    AgentCatalog[]
  versions        AgentVersion[]
  handoffAlerts   HandoffAlert[]

  @@index([workspaceId])
}

// ─── AGENT VERSION (prompt/config snapshots for rollback) ─────────────
model AgentVersion {
  id           String   @id @default(cuid())
  agentId      String
  label        String
  systemPrompt String   @db.Text
  model        String?
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(1000)
  note         String?
  createdAt    DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ─── CHANNEL CONNECTIONS ──────────────────────────────────────────
model AgentChannel {
  id              String      @id @default(cuid())
  agentId         String
  type            ChannelType
  config          Json // encrypted token/config
  active          Boolean     @default(true)
  webhookUrl      String?
  lastInboundAt   DateTime? // last time an inbound webhook message arrived (health signal)
  healthAlertedAt DateTime? // last time a "channel silent" alert was sent (dedup)
  createdAt       DateTime    @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@unique([agentId, type])
  @@index([agentId])
}

enum ChannelType {
  TELEGRAM
  WHATSAPP
  INSTAGRAM
  RUBIKA
  BALE
  WEB_WIDGET
  API
}

// ─── PRODUCT CATALOG ──────────────────────────────────────────────
model ProductCategory {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryTree")
  products  Product[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model Product {
  id                 String    @id @default(cuid())
  workspaceId        String
  categoryId         String?
  name               String
  description        String?   @db.Text
  price              Float?
  comparePrice       Float? // original price (for showing discount)
  sku                String?
  stock              Int? // null = unlimited
  images             String[] // Supabase Storage URLs
  attributes         Json? // {"color": "blue", "size": "XL"}
  tags               String[]
  active             Boolean   @default(true)
  embeddingUpdatedAt DateTime? // track when last embedded into vector store
  queryCount         Int       @default(0) // how many times AI retrieved this product
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace    Workspace        @relation(fields: [workspaceId], references: [id])
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  catalogItems AgentCatalog[]

  @@index([workspaceId])
  @@index([categoryId])
}

// Agent ↔ Product many-to-many (which products does each agent know about)
model AgentCatalog {
  id        String @id @default(cuid())
  agentId   String
  productId String

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([agentId, productId])
  @@index([agentId])
}

// ─── KNOWLEDGE BASE ───────────────────────────────────────────────
model KnowledgeBase {
  id          String   @id @default(cuid())
  agentId     String
  workspaceId String
  name        String
  type        KBType
  sourceUrl   String?
  fileKey     String?
  fileName    String?
  fileSize    Int?
  status      KBStatus @default(PENDING)
  chunkCount  Int      @default(0)
  errorMsg    String?
  // ─ F4: freshness tracking. For URL sources, lastIngestedAt records when the
  //   content was last re-fetched and re-embedded. refreshIntervalHours controls
  //   the automatic re-crawl cadence (0 = manual only).
  lastIngestedAt       DateTime?
  refreshIntervalHours Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent  Agent            @relation(fields: [agentId], references: [id])
  chunks KnowledgeChunk[]

  @@index([agentId])
  @@index([workspaceId])
}

enum KBType {
  PDF
  CSV
  URL
  TEXT
  FAQ
  PRODUCT_CATALOG
}

enum KBStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

// ─── KNOWLEDGE CHUNKS (with vector embeddings) ────────────────────
model KnowledgeChunk {
  id          String                       @id @default(cuid())
  kbId        String
  agentId     String
  workspaceId String
  content     String                       @db.Text
  metadata    Json? // {source, page, productId, sku, price}
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime                     @default(now())

  kb    KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  agent Agent         @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([workspaceId])
}

// ─── CONTACT (CRM) ────────────────────────────────────────────────
model Contact {
  id          String   @id @default(cuid())
  workspaceId String
  name        String?
  phone       String?
  telegramId  String?
  whatsappId  String?
  instagramId String?
  rubikaId    String?
  baleId      String?
  tags        String[]
  stage       String   @default("lead")
  notes       String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  conversations Conversation[]

  @@index([workspaceId])
  @@index([telegramId])
  @@index([phone])
}

// ─── CONVERSATION ─────────────────────────────────────────────────
model Conversation {
  id            String      @id @default(cuid())
  workspaceId   String
  agentId       String
  contactId     String?
  channel       ChannelType
  externalId    String?
  status        ConvStatus  @default(OPEN)
  handedOff     Boolean     @default(false)
  variant       String? // A/B experiment variant served to this conversation ('A' | 'B')
  rating        Int?
  summary       String?     @db.Text
  messageCount  Int         @default(0)
  lastMessageAt DateTime?
  // ─ F3: customer identification state. 'pending' until the contact has given
  //   their name+phone; 'collected' once captured. 'skipped' for channels where
  //   the platform identity is already trusted (messenger bots).
  customerInfoState String  @default("pending")
  identifiedAt      DateTime?
  createdAt     DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  agent     Agent     @relation(fields: [agentId], references: [id])
  contact   Contact?  @relation(fields: [contactId], references: [id])
  messages  Message[]
  handoffAlerts HandoffAlert[]

  @@unique([agentId, channel, externalId])
  @@index([workspaceId])
  @@index([agentId])
  @@index([contactId])
  @@index([externalId])
}

enum ConvStatus {
  OPEN
  RESOLVED
  HANDED_OFF
}

// ─── MESSAGE ──────────────────────────────────────────────────────
model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  contentType    ContentType @default(TEXT)
  audioUrl       String?
  metadata       Json?
  rating         Int?
  unanswered     Boolean     @default(false)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ContentType {
  TEXT
  AUDIO
  IMAGE
}

// ─── USAGE LOG ────────────────────────────────────────────────────
model UsageLog {
  id               String   @id @default(cuid())
  workspaceId      String
  agentId          String?
  date             DateTime @default(now())
  conversationId   String?
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  model            String?
  cost             Float?
  type             LogType

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, date])
}

enum LogType {
  CHAT
  EMBEDDING
  TTS
  STT
}

// ─── SUBSCRIPTION ─────────────────────────────────────────────────
model Subscription {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  plan             Plan
  status           SubStatus @default(ACTIVE)
  monthlyPrice     Float
  currency         String    @default("IRR") // Iranian Rial
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

enum SubStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

// ─── NOTIFICATION (in-app bell; may also fan out to email/SMS) ────────
model Notification {
  id          String           @id @default(cuid())
  workspaceId String
  type        NotificationType
  title       String
  body        String?          @db.Text
  link        String? // in-app deep link, e.g. /conversations/<id>
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, read, createdAt])
}

enum NotificationType {
  NEW_MESSAGE
  HANDOFF
  CHANNEL_DOWN
  LEARNING
  SYSTEM
}

// ─── ERROR LOG (surfaced in the /admin monitoring dashboard) ──────────
// Captured application errors so the operator can watch production health
// without tailing PM2 logs. Written fire-and-forget via captureError().
model ErrorLog {
  id          String   @id @default(cuid())
  level       String   @default("error") // error | warn
  source      String? // e.g. "chat-engine", "webhook:telegram"
  message     String   @db.Text
  stack       String?  @db.Text
  workspaceId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}

// ─── BLOG (SEO content marketing) ────────────────────────────────────
// Self-hosted blog under each workspace so the tenant can publish AI /
// product-related content to drive organic search traffic. Posts are
// Markdown-rendered server-side with full SEO metadata + JSON-LD.
model BlogCategory {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id])
  posts     BlogPost[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model BlogPost {
  id             String     @id @default(cuid())
  workspaceId    String
  categoryId     String?
  title          String
  slug           String
  excerpt        String?    @db.Text
  content        String     @db.Text // Markdown
  coverImage     String?
  status         BlogStatus @default(DRAFT)
  // SEO overrides (optional; defaults derived from title/excerpt/content)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]   @default([])
  canonicalUrl   String?
  ogImage        String?
  readingMinutes Int        @default(1) // auto-computed on save
  views          Int        @default(0)
  featured       Boolean    @default(false)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id])
  category  BlogCategory? @relation(fields: [categoryId], references: [id])

  @@unique([workspaceId, slug])
  @@index([workspaceId, status, publishedAt])
  @@index([workspaceId, featured])
  @@index([categoryId])
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

// ─── OPERATOR CHANNEL (F3) ───────────────────────────────────────────
//   A workspace's "operator Telegram bot": when an agent hands a conversation
//   off to a human, the alert + conversation summary is pushed to this bot so
//   the operator can read the context and reply. The operator replies inside
//   the same conversations panel in the dashboard (and optionally from their
//   own Telegram if the bot is configured with a chat id).
model OperatorChannel {
  id             String   @id @default(cuid())
  workspaceId    String   @unique // one operator bot per workspace for now
  botToken       String   // encrypted at rest by the app layer (lib/crypto)
  operatorChatId String?  // Telegram chat id where handoff alerts are sent
  botUsername    String?  // @username of the bot, shown to operators for /start
  active         Boolean  @default(true)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── HANDOFF ALERT (F3) ──────────────────────────────────────────────
//   A single handoff event: created when an agent escalates a conversation to a
//   human. Carries the snapshot of customer identity + conversation summary so
//   the operator has everything in one place without re-reading the whole thread.
model HandoffAlert {
  id             String   @id @default(cuid())
  workspaceId    String
  conversationId String
  agentId        String
  // Snapshot at handoff time — the contact's name/phone (if collected) and a
  // one-line summary so the operator can triage without opening the thread.
  contactName    String?
  contactPhone   String?
  channel        ChannelType
  reason         String?  @db.Text // keyword match, repeated fallbacks, manual
  summary        String?  @db.Text
  // 'open' = awaiting operator; 'claimed' = operator opened it; 'resolved' = done
  state          String   @default("open")
  claimedBy      String?  // operator user id (future)
  // Telegram message id of the alert we sent to the operator bot, so a later
  // operator reply in Telegram can be correlated back to this conversation.
  externalMessageId String?
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, state])
  @@index([conversationId])
  @@index([agentId])
}

// ─── STORE INTEGRATION (F2) ──────────────────────────────────────────
//   Connection to an external e-commerce store (WooCommerce, Shopify-like, or a
//   custom URL to crawl). Products and orders are pulled (or pushed via webhook)
//   into the workspace's catalog and a dedicated orders table so the agent can
//   answer "where is my order?" with live data.
model StoreIntegration {
  id           String   @id @default(cuid())
  workspaceId  String
  type         StoreType
  // For WooCommerce: store base URL (e.g. https://shop.example.com)
  storeUrl     String
  // API credentials (consumer key/secret for Woo REST, or a webhook signing secret)
  // encrypted at rest by the app layer.
  credentials  Json
  // HMAC secret used to verify inbound webhook pushes from the store plugin.
  webhookSecret String?
  // Polling cadence for the fallback sync (minutes). 0 = webhook only.
  pollIntervalMinutes Int @default(30)
  lastSyncAt   DateTime?
  lastSyncStatus String? // 'ok' | 'error'
  lastSyncError String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders    StoreOrder[]
  syncLogs  StoreSyncLog[]

  @@index([workspaceId])
}

enum StoreType {
  WOOCOMMERCE
  CUSTOM_URL
  SHOPIFY
}

// ─── STORE ORDER (F2) ────────────────────────────────────────────────
//   Lightweight mirror of an external order so the agent can answer order-status
//   questions. Updated by webhook push (plugin) and periodic poll (fallback).
model StoreOrder {
  id            String   @id @default(cuid())
  integrationId String
  workspaceId   String
  // The order number/id from the external store (e.g. Woo order #1234).
  externalOrderId String
  // Customer reference (matched to a Contact when possible by phone/email).
  contactId     String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  status        String   // 'pending' | 'processing' | 'on-hold' | 'completed' | 'cancelled' | 'refunded' | 'failed'
  total         Float
  currency      String   @default("IRR")
  itemCount     Int      @default(0)
  // Short line-item summary for the agent (e.g. "2× T-shirt, 1× Cap")
  itemsSummary  String?  @db.Text
  paymentMethod String?
  shippingMethod String?
  trackingCode  String?
  // ISO date strings from the store
  orderDate     DateTime?
  updatedAt     DateTime?
  createdAt     DateTime @default(now())

  integration StoreIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalOrderId])
  @@index([workspaceId])
  @@index([contactId])
  @@index([externalOrderId])
}

// ─── STORE SYNC LOG (F2) ─────────────────────────────────────────────
//   Audit trail of each sync attempt (products / orders / push / poll) so the
//   workspace owner can see what was imported and when, and debug failures.
model StoreSyncLog {
  id            String   @id @default(cuid())
  integrationId String
  workspaceId   String
  direction     String   // 'push' (webhook from store) | 'poll' (we fetched)
  entity        String   // 'products' | 'orders' | 'product_update' | 'order_update'
  outcome       String   // 'ok' | 'error'
  count         Int      @default(0)
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  integration StoreIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@index([workspaceId])
}
